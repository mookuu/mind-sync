# 复制为 .env 并修改所有密钥后再启动：cp .env.example .env
#
# ⚠️ 生产/公网暴露前必须修改：
#   AUTH_PASSWORD、SECRET_KEY、API_KEY

AUTH_PASSWORD=changeme
SECRET_KEY=replace-with-random-secret
API_KEY=mind-sync-dev-key
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_MAX_AGE_SECONDS=604800
SESSION_TTL_SECONDS=604800
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
API_RATE_LIMIT_WINDOW_SECONDS=3600
API_RATE_LIMIT_QUERY_MAX=30
API_RATE_LIMIT_SYNC_MAX=10
API_RATE_LIMIT_LINT_MAX=20
MAX_INDEX_FILE_BYTES=2000000
LINT_CONTENT_MAX_CHARS=500000
SECURITY_HSTS_ENABLED=false
CORS_ALLOW_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
CSRF_HEADER_NAME=x-csrf-token
AUDIT_RETENTION_DAYS=30
DATA_DIR=/data
SOURCES_FILE=/workspace/sources.yaml
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_API_KEY=
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash

# GitHub 私有仓 / Vault 同步（可选）
GITHUB_TOKEN=
VAULT_GIT_URL=
VAULT_GIT_BRANCH=main

# 本地 Ollama（未配置 LLM_API_KEY 时尝试）
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Docker 来源目录挂载（可选，覆盖 docker-compose 默认值）
# SOURCE_KNOWLEDGE_ENGINEERING=C:/Workspace/10.program/90.ai/knowledge_engineering
# SOURCE_JAVA_BASIC=C:/Workspace/10.program/10.language/JavaBasic
# SOURCE_PYTHON_BASIC=C:/Workspace/10.program/10.language/PythonBasic
