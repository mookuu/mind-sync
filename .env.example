# ---------------------------------------------------------------------------
# mind-sync 环境变量配置
# 复制本文件为 .env 并填充实际值:
#   cp .env.example .env    # Linux/macOS
#   copy .env.example .env  # Windows
# ---------------------------------------------------------------------------

# === 认证 ===
AUTH_PASSWORD=changeme
SECRET_KEY=replace-with-random-secret
API_KEY=mind-sync-dev-key

# === 数据层 ===
DATA_DIR=/data
SOURCES_FILE=/workspace/sources.yaml

# === LLM 问答 ===
LLM_BASE_URL='https://api-inference.modelscope.cn/v1/'
LLM_API_KEY='your-llm-api-key-here'
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash

# === 安全策略 ===
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_MAX_AGE_SECONDS=604800
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
SECURITY_HSTS_ENABLED=true

# === 本地源码路径（Docker 卷映射用） ===
# 生产环境请使用绝对路径或 Docker volume
SOURCE_KNOWLEDGE_ENGINEERING=./sources/knowledge_engineering
SOURCE_JAVA_BASIC=./sources/JavaBasic
SOURCE_PYTHON_BASIC=./sources/PythonBasic
