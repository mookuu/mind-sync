# ===========================================================================
# mind-sync 环境变量配置
# ===========================================================================
#
# 使用方式：
#   cp .env.example .env    # 复制
#   编辑 .env 填入实际值     # 不要提交 .env 到 git（已在 .gitignore）
#
# 变量加载顺序（docker compose up 时）：
#   Shell 环境变量  >  .env 文件  >  docker-compose.yml 中的 ${VAR:-fallback}
# ===========================================================================


# ===========================================================================
# 1. 认证 — 用户登录与权限
# ===========================================================================

# 默认管理员密码（至少 4 字符，未设 AUTH_USERS 时唯一生效）
AUTH_PASSWORD=your-admin-password

# 多用户配置（可选），格式：用户名:密码:角色,...
# 角色：admin=管理员  member=成员
# 密码建议 bcrypt 哈希：python scripts/generate_secrets.py hash-password 'your-pass'
# AUTH_USERS=bob:$2b$12$xxx:member,alice:$2b$12$yyy:member

# Session 加密密钥（自动生成或手动指定，切勿泄露）
SECRET_KEY=change-me-to-a-random-string

# API Key：绕过浏览器登录，供脚本/外部工具调用 API
# 使用方式：curl -H "X-API-Key: your-key" http://.../api/...
API_KEY=your-api-key-here


# ===========================================================================
# 2. 数据层 — 持久化路径与源配置文件
# ===========================================================================

# 容器内数据根目录（Docker volume 映射到宿主机，通常无需修改）
DATA_DIR=/data

# 宿主机数据目录（Docker volume 映射左侧路径）
DATA_ROOT=/home/moku/data/mind-sync-data

# sources.yaml 路径（容器内，由 docker-compose volume 挂载）
SOURCES_FILE=/workspace/sources.yaml


# ===========================================================================
# 3. LLM 问答 — QA 页面背后的模型
# ===========================================================================

# LLM API 地址（ModelScope / DeepSeek / Ollama / 自定义）
LLM_BASE_URL='https://api-inference.modelscope.cn/v1/'
# API Key
LLM_API_KEY='your-api-key-here'
# 模型名
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash


# ===========================================================================
# 4. 安全策略 — Cookie、登录限流、HSTS
# ===========================================================================

# Cookie secure 标志（生产 HTTPS 环境应设为 true）
COOKIE_SECURE=false
# Cookie SameSite 策略：strict / lax / none
COOKIE_SAMESITE=lax
# Cookie 有效期（秒），默认 7 天
COOKIE_MAX_AGE_SECONDS=604800

# 登录限流：时间窗口（秒）内最多尝试次数
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5

# HTTP Strict Transport Security（生产环境建议开启）
SECURITY_HSTS_ENABLED=true


# ===========================================================================
# 5. Web 源抓取 — type:web 的运行时行为控制（可选）
# ===========================================================================

# 是否启用 web 抓取（false 则所有 type:web 源被跳过）
WEB_FETCH_ENABLED=true

# 是否遵守 robots.txt（建议开启）
# WEB_FETCH_RESPECT_ROBOTS=true

# 请求 User-Agent 头
# WEB_FETCH_USER_AGENT=mind-sync/0.1

# 联系邮箱（填入 robots.txt 或网站管理员可用的联系方式）
# WEB_FETCH_CONTACT=you@example.com

# 同一域名抓取最小间隔（秒），防止请求过频被封
# WEB_FETCH_MIN_INTERVAL_SECONDS=5

# 抓取响应体最大字节数（超出截断）
# WEB_FETCH_MAX_BYTES=5000000

# 域名白名单（逗号分隔），只允许抓取列表内域名
# WEB_FETCH_ALLOWLIST=docs.python.org,github.com

# 是否强制白名单模式（true 则必须设 ALLOWLIST）
# WEB_FETCH_REQUIRE_ALLOWLIST=false

# 是否要求 sources.yaml 中 type:web 源显式声明 fetch_confirmed: true
# WEB_FETCH_REQUIRE_OPT_IN=false


# ===========================================================================
# 6. 搜索与同步 — 调优参数（可选）
# ===========================================================================

# 搜索分类权重（summary=学习摘要 query=问答沉淀 source=原始素材）
# SEARCH_CATEGORY_WEIGHTS=summary=1.2,query=1.1,source=1.0

# 同步失败退避：是否启用指数退避重试
# SYNC_BACKOFF_ENABLED=true
# 退避初始间隔（秒）
# SYNC_BACKOFF_BASE_SECONDS=60
# 退避最大间隔（秒）
# SYNC_BACKOFF_MAX_SECONDS=3600
# API 限流：时间窗口（秒）内每个 IP 最多允许的操作次数
# API_RATE_LIMIT_WINDOW_SECONDS=3600
# API_RATE_LIMIT_SYNC_MAX=10
# API_RATE_LIMIT_QUERY_MAX=30
# API_RATE_LIMIT_LINT_MAX=20


# ===========================================================================
# 7. 本地源码路径 — Docker 卷映射用
# ===========================================================================
# 宿主机绝对路径 → 容器内 /sources/<id> 映射
# 生产环境请使用绝对路径或 Docker volume

# Obsidian Web Clipper 导出目录
SOURCE_OBSIDIAN=./sources/obsidian

# Web 快照存放目录（type:web 源抓取的 md 存于此）
SOURCE_WEB_SNAPSHOTS=./sources/web_snapshots

# Wiki 知识库目录（摘要、问答沉淀）
SOURCE_WIKI=./sources/wiki

# GitHub 仓库示例（占位，需替换 url）
SOURCE_EXAMPLE_GITHUB=./sources/example_github
