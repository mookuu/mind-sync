{
  "private": true,
  "name": "mind-sync-web",
  "type": "module",
  "scripts": {
    "build:vendor": "npm run build:markdown && npm run build:highlight",
    "build:markdown": "esbuild md-bundle-entry.js --bundle --format=iife --outfile=vendor/markdown-it.bundle.js --minify",
    "build:highlight": "esbuild node_modules/highlight.js/lib/index.js --bundle --format=iife --global-name=hljs --outfile=vendor/highlight.min.js --minify",
    "test:markdown": "node test-markdown-render.mjs"
  },
  "dependencies": {
    "highlight.js": "11.9.0",
    "markdown-it": "^14.1.0",
    "markdown-it-task-lists": "^2.1.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
